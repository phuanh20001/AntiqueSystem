# ===============================================
# DATABASE CONFIGURATION
# ===============================================

# MongoDB Connection URI
# For local MongoDB:
# MONGO_URI=mongodb://127.0.0.1:27017/antique_db

# For MongoDB Atlas (recommended for production):
# MONGO_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/antique_db?retryWrites=true&w=majority

MONGO_URI=mongodb://127.0.0.1:27017/antique_db

# ===============================================
# SERVER CONFIGURATION
# ===============================================

PORT=5000
NODE_ENV=development

# ===============================================
# JWT AUTHENTICATION
# ===============================================

JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# ===============================================
# BLOCKCHAIN CONFIGURATION (Ethereum/Sepolia)
# ===============================================

# Alchemy Sepolia RPC URL
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Smart Contract Address (deployed AntiqueVerification contract)
CONTRACT_ADDRESS=0x_YOUR_CONTRACT_ADDRESS_HERE

# Deployer Private Key (for signing blockchain transactions)
DEPLOYER_PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# ===============================================
# API CONFIGURATION
# ===============================================

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ===============================================
# EMAIL CONFIGURATION (Optional)
# ===============================================

# For sending verification emails, notifications, etc.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
EMAIL_FROM=noreply@antique-system.com

# ===============================================
# FILE UPLOAD CONFIGURATION
# ===============================================

# Maximum file size for image uploads (in bytes)
MAX_FILE_SIZE=5242880  # 5MB

# Allowed image file types
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif

# Upload directory
UPLOAD_DIR=./uploads
